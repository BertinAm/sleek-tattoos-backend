# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Core ---
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.sleektattoos.com

# --- Database ---
# Local dev: leave DATABASE_URL unset to fall back to SQLite (db.sqlite3).
# Production (Namecheap Stellar / MySQL): set this to your cPanel MySQL database.
#   mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME
DATABASE_URL=

# --- CORS / frontend trust ---
# Comma-separated list of origins allowed to call this API (no trailing slash).
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://sleektattoos.com,https://www.sleektattoos.com

# --- JWT ---
# Access token lifetime in minutes, refresh token lifetime in days.
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=14

# --- Google Calendar (service account, see deployment.md) ---
# Absolute path to the service account JSON key file. Must live OUTSIDE the
# git repo and outside public_html on the server. Leave blank to disable
# calendar sync (bookings still save to the database either way).
GOOGLE_SERVICE_ACCOUNT_FILE=
# The owner's Gmail/Calendar address the service account has been shared with.
GOOGLE_CALENDAR_OWNER_EMAIL=

# --- Email (Namecheap-hosted mailboxes, cPanel mail) ---
# localhost:25, NOT the public sleektattoos.com:465 the mailboxes' own
# "Connect Devices" page advertises — confirmed on Stellar that outbound
# connections to remote SMTP ports from the Python App process are
# firewalled (instant "Network is unreachable", not a slow/bad-credentials
# failure). localhost:25 reaches cPanel's local Exim MTA directly and works.
# See memory.md before changing this back to the public host/port.
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_USE_SSL=False
# Sends booking notification emails.
EMAIL_HOST_USER=hello@sleektattoos.com
EMAIL_HOST_PASSWORD=
# Sends admin-login-alert emails — a real, separate mailbox (SMTP needs to
# authenticate as whoever it sends "From", not just fake the header).
NOREPLY_EMAIL_HOST_USER=noreply@sleektattoos.com
NOREPLY_EMAIL_HOST_PASSWORD=
# Where both kinds of notification emails actually get delivered.
STUDIO_NOTIFICATION_EMAIL=sleektattoos00@gmail.com

# --- Media (uploaded images) ---
# Local dev serves /media/ from Django itself. In production this can stay
# the same on Stellar (small studio scale) — see deployment.md for details.
MEDIA_URL=/media/

# --- Production security (only read when DJANGO_DEBUG=False, see settings.py) ---
# Origins allowed to submit state-changing requests against Django's own
# session/CSRF-cookie-based /admin/ site (NOT the JWT API — that's covered by
# CORS_ALLOWED_ORIGINS above). Usually just the frontend's real domain(s).
DJANGO_CSRF_TRUSTED_ORIGINS=https://sleektattoos.com,https://www.sleektattoos.com
# Set to False only if TLS termination happens somewhere Django can't detect
# it (unlikely on this stack) — leave True once HTTPS is confirmed working.
DJANGO_SECURE_SSL_REDIRECT=True
# HSTS max-age in seconds. Only takes effect once HTTPS is verified end-to-end
# — an HSTS mistake locks out plain-HTTP access for this long. Defaults to
# 1 year if unset.
DJANGO_HSTS_SECONDS=31536000
